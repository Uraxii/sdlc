# Path to the caveman-compress repo root (the directory that contains scripts/)
# Example: /home/user/.claude/plugins/marketplaces/caveman/caveman-compress
CAVEMAN_COMPRESS_DIR=

# Anthropic API key for SDK-based Claude calls (faster, more reliable in CI)
# If unset, build.py falls back to the 'claude' CLI (requires desktop auth)
ANTHROPIC_API_KEY=

# WARNING: build output includes LLM-compressed files. Spot-check dist/staging/agents/
# before tagging a release — validate() checks structure, not semantic fidelity.
